#!/bin/bash

res=($(xrandr | awk '/primary/{sub(/+.*$/,"",$4); sub(/x/," ",$4); print $4}'))
size=($(awk '/\s+DisplaySize/{print $2, $3}' /etc/X11/xorg.conf.d/*-monitor.conf))
if [ ${#size[@]} -eq 0 ]; then
    size=($(xrandr | awk '/primary/{sub(/\(.*\)/,"",$0); sub(/mm/,"",$5); sub(/mm/,"",$7); print $5, $7}'))
fi

rw=${res[0]}
rh=${res[1]}
sw=${size[0]}
sh=${size[1]}

dpi=$(bc -l <<< "scale=2; sqrt($rw ^ 2 + $rh^2) / (sqrt($sw ^ 2 + $sh ^ 2) / 25.4)")
printf "%.0f\n" $dpi
