#!/bin/bash
set -e

#----------------------------------------------------------------------
# Help
#----------------------------------------------------------------------
USAGE="Usage: $(basename $0) [OPTION]... [THEME]"
HELP="\
$(basename $0) [OPTION]... [THEME]
Flags:
  -h,--help                     prints current help message
  -l,--list                     prints available themes
"

function die() { echo >&2 "$*"; exit 1; }
function usage() { die "$USAGE"; }
function help() { echo "$HELP"; }

#----------------------------------------------------------------------
# Constants
#----------------------------------------------------------------------
THEMES_FILE=$HOME/.cache/$(basename $0)/themes.json

#----------------------------------------------------------------------
# Arguments
#----------------------------------------------------------------------
LIST_THEMES=0

case "$#" in
    0)
        usage ;;
    *)
        while [ $# -gt 0 ]; do
            case "$1" in
                -h|--help)
                    help
                    exit 0
                    ;;
                -l|--list)
                    LIST_THEMES=1
                    ;;
                *)
                    break ;;
            esac
            shift
        done
esac

if [ $LIST_THEMES -eq 0 ]; then
    if [ $# -ne 1 ]; then
        die "Missing theme name argument"
    fi
    THEME_NAME="$1"
fi

#----------------------------------------------------------------------
# Functions
#----------------------------------------------------------------------
fetch() {
    curl -s -O --create-dirs --output-dir $(dirname $THEMES_FILE) \
        https://raw.githubusercontent.com/Mayccoll/Gogh/master/data/themes.json
}

list() {
    jq -r '.themes[].name' $THEMES_FILE
}

apply() {
    local theme="$1"
    echo Setting theme to "$theme"
    jq ".themes
        | map({key: .name, value: del(.name)})
        | from_entries
        | (.\"$theme\")
        | {
            special: {
              background: .background,
              foreground: .foreground,
              cursor: .cursor,
            },
            colors: {
              color0: .color_01,
              color1: .color_02,
              color2: .color_03,
              color3: .color_04,
              color4: .color_05,
              color5: .color_06,
              color6: .color_07,
              color7: .color_08,
              color8: .color_09,
              color9: .color_10,
              color10: .color_11,
              color11: .color_12,
              color12: .color_13,
              color13: .color_14,
              color14: .color_15,
              color15: .color_16,
            }
          }" $THEMES_FILE > /tmp/temp-wal.conf
    wal -o refresh -f /tmp/temp-wal.conf
}

#----------------------------------------------------------------------
# Entrypoint
#----------------------------------------------------------------------
# Fetch themes file if not found
if [ ! -f $THEMES_FILE ]; then
    fetch
fi

# Gather theme names
readarray -t themelist < <(list)

# List themes
if [ $LIST_THEMES -eq 1 ]; then
    printf '%s\n' "${themelist[@]}"
    exit 0
fi

# Check if theme exists
if [[ ! " ${themelist[*]} " =~ " ${THEME_NAME} " ]]; then
    die "Theme \"$THEME_NAME\" does not exist"
fi

# Set the theme
apply "$THEME_NAME"
