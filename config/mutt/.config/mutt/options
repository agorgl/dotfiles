#
# Index
#
# How to sort messages in the “index” menu
set sort = "reverse-date"
# Enable threaded view where roots appear above children
set use_threads = yes

#
# Pager
#
# Do not move to the next message when you are at the end of a message
set pager_stop = yes
# Do not display '+' markers in the beggining of wrapped lines
set markers = no
